# Environment
ENVIRONMENT=production

# Firebase
FIREBASE_DISABLED=1
# Ou use o JSON minificado em linha única:
FIREBASE_CREDENTIALS={"type":"service_account","project_id":"..."}

# Server
PORT=8000
MAX_FILE_SIZE=52428800

# CORS - Frontend URL
FRONTEND_URL=https://seu-frontend.vercel.app
FRONTEND_URLS=https://seu-frontend.vercel.app,https://seu-preview.vercel.app

# AI
GEMINI_API_KEY=sua-chave-aqui
# OPENROUTER_API_KEY=
# GROQ_API_KEY=
# OpenAI (deixe vazio até o cliente fornecer a chave real)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_ORCAMENTO_MODEL=gpt-4o
OPENAI_ORCAMENTO_TIMEOUT=120

# Deploy
RAILWAY_PUBLIC_DOMAIN=seu-backend.railway.app
