# Environment
ENVIRONMENT=development

# Firebase
FIREBASE_DISABLED=1
# Ou use o JSON minificado em linha única:
FIREBASE_CREDENTIALS={"type":"service_account","project_id":"..."}

# Server
PORT=8001
MAX_FILE_SIZE=52428800

# CORS - Frontend URL
FRONTEND_URL=http://localhost:8000
FRONTEND_URLS=http://localhost:8000

# AI
GEMINI_API_KEY=sua-chave-aqui
# OPENROUTER_API_KEY=
# GROQ_API_KEY=
# OPENAI_API_KEY=

# Deploy
RAILWAY_PUBLIC_DOMAIN=seu-backend.railway.app
